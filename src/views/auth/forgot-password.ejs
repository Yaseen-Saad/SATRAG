<% title = 'Forgot Password'; %>
<div class="auth-layout">
  <div class="auth-brand">
    <div class="auth-brand-name">SATrack</div>
    <p class="auth-brand-tagline">No worries. We'll send you a reset link.</p>
  </div>
  <div class="auth-form-wrap">
    <div class="auth-card">
      <h1>Forgot Password</h1>
      <p class="auth-subtitle">Enter your email and we'll send a reset link</p>
      <%- include('../partials/flash') %>
      <form method="POST" action="/auth/forgot-password" data-loading x-data="loadingForm()" @submit="submit()">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@example.com">
        </div>
        <button type="submit" class="btn-primary btn-block btn-lg" :class="{ 'is-loading': loading }" :disabled="loading">Send Reset Link</button>
      </form>
      <div class="auth-footer">
        <p>Remember your password? <a href="/auth/login">Log in</a></p>
      </div>
    </div>
  </div>
</div>
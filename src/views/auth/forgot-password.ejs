<% title = 'Forgot Password'; %>
<div class="auth-page">
  <div class="auth-card">
    <h1>Reset Password</h1>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="flash flash-error"><%= error %><button class="dismiss">×</button></div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="flash flash-success"><%= success %><button class="dismiss">×</button></div>
    <% } else { %>
    <form method="POST" action="/auth/forgot-password" data-loading>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
        <div class="hint">We'll send you a password reset link.</div>
      </div>
      <button type="submit" class="btn-primary btn-block">Send Reset Link</button>
    </form>
    <% } %>

    <div class="auth-footer">
      <a href="/auth/login">Back to Login</a>
    </div>
  </div>
</div>
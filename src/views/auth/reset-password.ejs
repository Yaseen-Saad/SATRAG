<% title = 'Reset Password'; %>
<div class="auth-page">
  <div class="auth-card">
    <h1>Set New Password</h1>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="flash flash-error"><%= error %><button class="dismiss">×</button></div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="flash flash-success"><%= success %><button class="dismiss">×</button></div>
    <% } else { %>

    <div id="noToken" class="flash flash-warning" style="display:none;">
      No reset token found. Request a new password reset link.
      <button class="dismiss">×</button>
    </div>

    <form method="POST" action="/auth/reset-password" id="resetForm" data-loading>
      <input type="hidden" id="accessTokenInput" name="access_token" value="">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
      </div>
         <div class="form-group password-field">
        <label id="form-group-title" for="newPassword">New Password<span>*</span></label>
        <input type="password" id="newPassword" name="newPassword" placeholder="At least 6 characters" required>
        <button type="button" class="password-toggle" onclick="togglePassword(this)" aria-label="Toggle password visibility">👁️</button>
      </div>
      <button type="submit" class="btn-primary btn-block">Update Password</button>
    </form>
    <% } %>

    <div class="auth-footer">
      <a href="/auth/login">Back to Login</a>
    </div>
  </div>
</div>

<script>
  (function() {
    var hash = window.location.hash.substring(1);
    var params = new URLSearchParams(hash);
    var token = params.get('access_token');
    if (token) {
      document.getElementById('accessTokenInput').value = token;
    } else {
      var form = document.getElementById('resetForm');
      if (form) form.style.display = 'none';
      var noToken = document.getElementById('noToken');
      if (noToken) noToken.style.display = 'block';
    }
  })();
</script>
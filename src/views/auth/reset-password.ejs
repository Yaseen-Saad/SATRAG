<% title = 'Reset Password'; %>
<div style="max-width:400px; margin:2rem auto;">
  <h1>Reset Password</h1>

  <% if (error) { %>
  <div class="flash-error"><%= error %></div>
  <% } %>

  <% if (success) { %>
  <div class="flash-success"><%= success %></div>
  <% } %>

  <div class="card">
    <form method="POST" action="/auth/reset-password">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="yasoo@example.com" required class="form-input">
      </div>
      <div class="form-group">
        <label for="newPassword">New Password</label>
        <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password" required class="form-input">
      </div>
      <button type="submit" class="btn-primary" style="width:100%;">Reset Password</button>
    </form>
  </div>
  <p style="text-align:center; margin-top:1rem;">
    <a href="/auth/login">Back to Login</a>
  </p>
</div>
<script>
  (function() {
    const hash = window.location.hash.substring(1)
    const urlParams = new URLSearchParams(hash);
    const token = urlParams.get('access_token');
    if (token) {
      const form = document.querySelector('form');
      const tokenInput = document.createElement('input');
      tokenInput.type = 'hidden';
      tokenInput.name = 'token';
      tokenInput.value = token;
      form.appendChild(tokenInput);
    }
  })();
</script>
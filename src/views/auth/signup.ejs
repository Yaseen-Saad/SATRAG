<% include ../layouts/main.ejs %>
<h1>Login</h1>
<% if (typeof error !== 'undefined' && error) { %>
<p style="color:red;"><%= error %></p>
<% } %>
<form method="POST" action="/auth/signup">
  <input type="email" name="email" placeholder="Email" required style="display:block; width:100%; margin-bottom:1rem; padding:0.5rem;">
  <input type="password" name="password" placeholder="Password" required style="display:block; width:100%; margin-bottom:1rem; padding:0.5rem;">
  <button type="submit" style="padding:0.5rem 2rem; background:#1a1a2e; color:white; border:none; cursor:pointer;">Sign Up </button>
</form>
<p>Already have an account? <a href="/auth/login">Login</a></p>
<% title = 'Sign Up'; %>
<div class="auth-page">
  <div class="auth-card">
    <h1>Create Account</h1>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="flash flash-error"><%= error %><button class="dismiss">×</button></div>
    <% } %>

    <form method="POST" action="/auth/signup" data-loading>
      <div class="form-group">
        <label id="form-group-title" for="firstName">First Name<span>*</span></label>
        <input type="text" id="firstName" name="firstName" placeholder="Yaseen" required>
      </div>
      <div class="form-group">
        <label id="form-group-title" for="lastName">Last Name<span>*</span></label>
        <input type="text" id="lastName" name="lastName" placeholder="Mohamed" required>
      </div>
      <div class="form-group">
        <p id="form-group-title">Gender<span>*</span></p>
        <div class="form-radio-holder">
          <input type="radio" id="male" name="gender" value="male" required>
          <label for="male">Male</label>
          <input type="radio" id="female" name="gender" value="female" required>
          <label for="female">Female</label>
        </div>
      </div>
      <div class="form-group">
        <label for="hearfrom">Where did you hear about us from?</label>
        <select id="hearfrom" name="hearfrom">
          <option value="" disabled selected>Select an option</option>
          <option value="friend">Friend</option>
          <option value="socialmedia">Social Media</option>
          <option value="teacher">Teacher</option>
          <option value="school">School</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="form-group">
        <label id="form-group-title" for="email">Email<span>*</span></label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label id="form-group-title" for="password">Password<span>*</span></label>
        <input type="password" id="password" name="password" placeholder="At least 6 characters" required minlength="6">
      </div>
      <button type="submit" class="btn-primary btn-block btn-lg">Sign Up</button>
    </form>

    <div class="auth-footer">
      Already have an account? <a href="/auth/login">Log in</a>
    </div>
  </div>
</div>
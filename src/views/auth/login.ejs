<% title = 'Log In'; %>
<div class="auth-page">
  <div class="auth-card">
    <h1>Welcome Back</h1>
    <% if (typeof error !== 'undefined' && error){ %>
    <div class="flash flash-error"><%= error %><button class="dismiss">&times;</button></div>
    <% } %>
    <form method="POST" action="/auth/login" data-loading>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="form-group password-field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter your password" required>
        <button type="button" class="password-toggle" aria-label="Toggle password visibility" onclick="togglePassword(this)">Show</button>
      </div>
      <div class="form-group">
        <label for="remember" class="checkbox-label">
          <input type="checkbox" value="1" id="remember" name="remember">
          <span> Remember me for a month</span>
        </label>
      </div>
      <button type="submit" class="btn-primary btn-block btn-lg">Log In</button>
    </form>

    <div class="auth-footer">
      <a href="/auth/forgot-password">Forgot your password?</a>
      <br>
      Don't have an account? <a href="/auth/signup">Sign up</a>
    </div>
  </div>
</div>
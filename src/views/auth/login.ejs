<% title = 'Login'; %>
<div style="max-width:400px; margin:2rem auto;">
  <h1>Login</h1>
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="flash-error"><%= error %></div>
  <% } %>
  <div class="card">
    <form method="POST" action="/auth/login">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required class="form-input">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required class="form-input">
      </div>
      <button type="submit" class="btn-primary" style="width:100%;">Login</button>
    </form>
  </div>
  <p style="text-align:center; margin-top:1rem;">Don't have an account? <a href="/auth/signup">Sign up</a></p>
</div>

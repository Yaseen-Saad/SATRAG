<% title = 'Log In'; %>
<div class="auth-layout">
  <div class="auth-brand">
    <div class="auth-brand-name">SATrack</div>
    <p class="auth-brand-tagline">Welcome back. Your words and progress are waiting.</p>
  </div>
  <div class="auth-form-wrap">
    <div class="auth-card">
      <h1>Log In</h1>
      <p class="auth-subtitle">Welcome back to SATrack</p>
      <%- include('../partials/flash') %>
      <form method="POST" action="/auth/login" data-loading x-data="loadingForm()" @submit="submit()">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@example.com">
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <div class="password-field">
            <input type="password" id="password" name="password" required autocomplete="current-password">
            <button type="button" class="password-toggle" onclick="var inp=this.previousElementSibling;var vis=inp.type==='text';inp.type=vis?'password':'text';this.querySelector('.eye-open').style.display=vis?'block':'none';this.querySelector('.eye-closed').style.display=vis?'none':'block'" aria-label="Show password"><img src="/img/eyeopen.svg" alt="" class="eye-open" width="18" height="18"><img src="/img/eyeclosed.svg" alt="" class="eye-closed" width="18" height="18" style="display:none"></button>
          </div>
        </div>
        <div class="checkbox-row">
          <input type="checkbox" id="remember" name="remember" value="1">
          <label for="remember" style="font-size:var(--text-sm); color:var(--color-text-sec);">Remember me</label>
        </div>
        <button type="submit" class="btn-primary btn-block btn-lg" :class="{ 'is-loading': loading }" :disabled="loading">Log In</button>
      </form>
      <div class="auth-footer">
        <p><a href="/auth/forgot-password">Forgot password?</a></p>
        <p style="margin-top:var(--sp-2);">Don't have an account? <a href="/auth/signup">Sign up</a></p>
      </div>
    </div>
  </div>
</div>
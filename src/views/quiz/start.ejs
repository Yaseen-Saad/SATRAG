<% title = 'Start a Quiz'; %>
<h1>Practice Quiz</h1>
<% if (typeof error !== 'undefined' && error) { %>
  <div style="background:#ffebee; color:#c62828; padding:0.75rem; border-radius:4px; margin-bottom:1rem;"><%= error %></div>
<% } %>

<div style="background:#f5f5f5; padding:1.5rem; border-radius:8px;">
  <form method="POST" action="/quiz/create">
    <% if (typeof word !== 'undefined' && word) { %>
      <input type="hidden" name="word" value="<%= word %>">
      <p>Quiz on: <strong><%= word %></strong></p>
    <% } %>
    <div style="margin-bottom:1rem;">
      <label>Number of questions:</label>
      <select name="count" style="display:block; width:100%; padding:0.5rem; margin-top:0.25rem; border:1px solid #ccc; border-radius:4px;">
        <option value="3">3 (Quick)</option>
        <option value="5" selected>5 (Standard)</option>
        <option value="10">10 (Challenge)</option>
      </select>
    </div>
    <button type="submit" style="padding:0.75rem 2rem; background:#1a1a2e; color:white; border:none; border-radius:4px; cursor:pointer; font-size:1rem;">
      Start Quiz
    </button>
  </form>
</div>
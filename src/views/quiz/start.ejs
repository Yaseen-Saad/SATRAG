<% title = 'Start a Quiz'; %>
<h1>Practice Quiz</h1>
<% if (typeof error !== 'undefined' && error) { %>
<div class="flash-error"><%= error %></div>
<% } %>

<div class="card" style="max-width:500px;">
  <form method="POST" action="/quiz/create">
    <% if (typeof word !== 'undefined' && word) { %>
    <input type="hidden" name="word" value="<%= word %>">
    <div class="flash-info">Quiz on: <strong><%= word %></strong></div>
    <% } %>

    <div class="form-group">
      <label for="count">Number of questions:</label>
      <select name="count" id="count" class="form-input">
        <option value="3">3 (Quick)</option>
        <option value="5" selected>5 (Standard)</option>
        <option value="10">10 (Challenge)</option>
      </select>
    </div>

    <button type="submit" class="btn-primary">Start Quiz</button>
  </form>
</div>

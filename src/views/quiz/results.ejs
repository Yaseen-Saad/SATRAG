<% title = 'Quiz Results'; %>
<h1>Results</h1>

<div class="card" style="text-align:center; margin-bottom:2rem;">
  <h2 style="font-size:2.5rem; margin:0; color:<%= attempt.score >= 70 ? '#2e7d32' : attempt.score >= 50 ? '#ff8f00' : '#c62828' %>;">
    <%= attempt.score %>% / 100%
  </h2>
  <p style="color:#666; margin-top:0.5rem;"><%= attempt.score >= 70 ? 'Great job!' : attempt.score >= 50 ? 'Keep practicing!' : 'Review these words and try again.' %></p>
  <p><%= attempt.score >= 70 ? '✅' : '📚' %> <%= attempt.score %>% — <%= attempt.total_questions %> questions</p>
</div>

<% if (typeof questions !== 'undefined' && questions.length > 0) { %>
<h2>Review</h2>
<% questions.forEach((q, i) => { %>
<div class="card" style="margin-bottom:0.75rem;">
  <p style="font-weight:bold; margin-bottom:0.5rem; font-size:0.85rem; color:#888;">Question <%= i + 1 %></p>
  <p><%= q.prompt %></p>
  <p style="color:<%= q.is_correct ? '#2e7d32' : '#c62828' %>; margin-top:0.5rem;">
    <%= q.is_correct ? '✅ Correct' : '❌ Incorrect' %>
    <% if (!q.is_correct) { %>
    — Correct answer: <strong><%= JSON.parse(q.options)[q.correct_index] %></strong>
    <% } %>
  </p>
</div>
<% }) %>
<% } %>

<div style="margin-top:1.5rem; display:flex; gap:0.5rem;">
  <a href="/quiz/start" class="btn-primary">Try Again</a>
  <a href="/vocab" class="btn-secondary">Study Vocab</a>
</div>

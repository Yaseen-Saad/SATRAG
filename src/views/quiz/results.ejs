<% title = 'Quiz Results'; %>
<h1>Results</h1>

<div style="background:#f5f5f5; padding:1.5rem; border-radius:8px; text-align:center; margin-bottom:2rem;">
  <h2 style="font-size:2.5rem; margin:0; color:<%= attempt.score >= 70 ? '#2e7d32' : attempt.score >= 50 ? '#ff8f00' : '#c62828' %>;">
    <%= attempt.score %>% / 100%
  </h2>
  <p style="color:#666;"><%= attempt.score >= 70 ? 'Great job!' : attempt.score >= 50 ? 'Keep practicing!' : 'Review these words and try again.' %></p>
  <p><%= attempt.score >= 70 ? '✅' : '📚' %> <%= attempt.score %>% — <%= attempt.total_questions %> questions</p>
</div>

<% if (typeof questions !== 'undefined' && questions.length > 0) { %>
<h2>Review</h2>
<% questions.forEach((q, i) => { %>
<div style="background:white; border:1px solid #ddd; border-radius:8px; padding:1rem; margin-bottom:1rem;">
  <p style="font-weight:bold; margin-bottom:0.5rem;">Question <%= i + 1 %></p>
  <p><%= q.prompt %></p>
  <p style="color:<%= q.is_correct ? '#2e7d32' : '#c62828' %>; margin-top:0.5rem;">
    <%= q.is_correct ? '✅ Correct' : '❌ Incorrect' %>
    <% if (!q.is_correct) { %>
    — Correct answer: <strong><%= JSON.parse(q.options)[q.correct_index] %></strong>
    <% } %>
  </p>
</div>
<% }) %>
<% } %>

<div style="margin-top:1.5rem; display:flex; gap:0.5rem;">
  <a href="/quiz/start" style="padding:0.75rem 1.5rem; background:#1a1a2e; color:white; text-decoration:none; border-radius:4px;">Try Again</a>
  <a href="/vocab" style="padding:0.75rem 1.5rem; background:#16213e; color:white; text-decoration:none; border-radius:4px;">Study Vocab</a>
</div>
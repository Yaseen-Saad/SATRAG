<% title = 'Flashcards' %>
<div class="fc-page">
  <div class="fc-header">
    <h1>Flashcards</h1>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="fc-stats">
    <div class="fc-stat due">
      <div class="fc-stat-value"><%= stats.dueToday %></div>
      <div class="fc-stat-label">Due Today</div>
    </div>
    <div class="fc-stat studying">
      <div class="fc-stat-value"><%= stats.totalCards - stats.mastered %></div>
      <div class="fc-stat-label">Studying</div>
    </div>
    <div class="fc-stat mastered">
      <div class="fc-stat-value"><%= stats.mastered %></div>
      <div class="fc-stat-label">Mastered</div>
    </div>
    <div class="fc-stat total">
      <div class="fc-stat-value"><%= stats.totalCards %></div>
      <div class="fc-stat-label">Total Cards</div>
    </div>
  </div>

  <h2 style="margin-top:1.5rem;">Your Lists</h2>

  <% if (!lists || lists.length === 0) { %>
    <div class="fc-empty">
      <p>No word lists yet. Create a list from the <a href="/vocab">vocab page</a> to get started.</p>
    </div>
  <% } else { %>
    <div class="fc-list-grid">
      <% var listDueMap = {}; listDueCounts.forEach(function(ld) { listDueMap[ld.id] = ld.dueCount; }); %>
      <% lists.forEach(function(list) { %>
        <div class="fc-list-row">
          <div class="fc-list-row-info">
            <a href="/vocab/lists/<%= list.id %>" class="fc-list-row-name"><%= list.name %></a>
            <div class="fc-list-row-meta">
              <%= list.word_count || 0 %> words ·
              <%= listDueMap[list.id] || 0 %> due
            </div>
          </div>
          <div class="fc-list-row-action">
            <form method="POST" action="/flashcards/list/<%= list.id %>/start" style="display:inline;">
              <button type="submit" class="btn btn-primary btn-sm">
                <% if ((listDueMap[list.id] || 0) > 0) { %>Study<% } else { %>Review All<% } %>
              </button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
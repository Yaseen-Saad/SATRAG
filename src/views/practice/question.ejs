<% title = 'Question'; %>
<% if (!question) { %>
<div class="flash flash-error"><%= error || 'Question not found' %></div>
<a href="/practice" class="btn btn--primary">Back to Bank</a>
<% } else { %>
<% let opts =[]; try{ opts= question.options ? (typeof question.options === 'string' ? JSON.parse(question.options) : question.options) : []; } catch(e) { console.error('Error parsing question options:', e); } %>
<% const hasPassage = !!question.passage_text; %>

<div class="bluebook">
  <div style="display:none" id="question-data" data-id="<%= question.id %>" data-status="<%= uState?.status || 'unsolved'%>" data-answered="<%= (uState?.status && uState.status !== 'unsolved') ? 'true':'false'%>" data-correct="<%=uState?.status === 'solved_correct'?'true':'false'%>" data-attempts="<%=JSON.stringify(attempts || [])%>"></div>
  <div style="display:none" id="return-to" data-url="<%= returnTo || '/practice'%>"></div>

  <!-- TOP BAR -->
  <header class="bb-topbar">
    <div class="bb-topbar-left">
      <a href="<%=returnTo || '/practice'%>" class="bb-back-link">← Back to Bank</a>
      <span style="opacity:0.4; font-size:0.8rem;"><%= (question.subject === 'reading' || question.subject === 'writing') ? 'Reading & Writing' : question.subject %> · <%= question.difficulty %></span>
    </div>
    <div class="bb-topbar-center">
      <span class="bb-question-label">Question <span id="q-num">1</span></span>
    </div>
    <div class="bb-topbar-right">
      <button class="bb-mark-btn <%= uState?.marked_for_review ? 'marked' : '' %>" id="mark-btn" onclick="toggleMarkBtn()">
        <%= uState?.marked_for_review ? '★ Marked' : '☆ Mark for Review' %>
      </button>
      <span class="bb-timer" id="timer">00:00</span>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <div class="bb-main <%= hasPassage ? '' : 'single-panel' %>">
    <% if (hasPassage) { %>
    <div class="bb-panel bb-panel-passage">
      <div class="bb-passage-content">
        <% 
          const lines = (question.passage_text || '').split('\n');
          lines.forEach(line => {
            if (line.trim()) {
              const words = line.trim();
        %>
        <p><%- words %></p>
        <% } }); %>
      </div>
    </div>
    <% } %>

    <div class="bb-panel bb-panel-question">
      <div class="bb-stem"><%- question.question_text %></div>

      <% if (question.question_type === 'mcq' && opts.length) { %>
      <div class="bb-options">
        <% opts.forEach(opt => { %>
        <button class="bb-option" data-label="<%= opt.label %>" onclick="window.selectOption('<%= opt.label %>')">
          <span class="bb-option-bubble"><%= opt.label %></span>
          <span class="bb-option-text"><%- opt.content %></span>
          <span class="bb-eliminate-btn">−</span>
        </button>
        <% }) %>
      </div>
      <button class="bb-fb-btn primary" id="submit-btn" onclick="window.submitAnswer()" style="margin-top:1rem; padding:0.65rem 2rem; font-size:1rem;" disabled>Check Answer</button>
      <% } else { %>
      <div class="bb-spr-input">
        <input type="text" id="spr-answer" placeholder="Enter your answer" autocomplete="off">
        <button onclick="submitAnswer(document.getElementById('spr-answer').value.trim())">Submit</button>
      </div>
      <% } %>
    </div>
  </div>

  <!-- BOTTOM BAR -->
  <footer class="bb-bottombar">
    <div class="bb-bottombar-left">
      <% if (prevId) { %><a href="/practice/question/<%= prevId %><%returnTo? '?from='+encodeURIComponent(returnTo):''%>" class="bb-nav-btn">◀ Previous</a><% } else { %><a href="<%=returnTo || '/practice'%>" class="bb-nav-btn">◀ Back</a><% } %>
    </div>
    <div class="bb-bottombar-center">
      <button class="bb-palette-toggle" onclick="openPalette()">☰ Questions</button>
    </div>
    <div class="bb-bottombar-right">
      <% if (nextId) { %><a href="/practice/question/<%= nextId %><%returnTo? '?from='+encodeURIComponent(returnTo):''%>" class="bb-nav-btn">Next ▶</a><% } else { %><a href="<%=returnTo || '/practice'%>" class="bb-nav-btn">Done</a><% } %>
    </div>
  </footer>
</div>

<!-- FEEDBACK OVERLAY -->
<div class="bb-feedback-overlay" id="feedback-overlay">
  <div class="bb-feedback"></div>
</div>

<!-- QUESTION PALETTE OVERLAY -->
<div class="bb-palette-overlay" id="palette-overlay">
  <div class="bb-palette">
    <div class="bb-palette-header">
      <h3>Questions</h3>
      <button onclick="closePalette()">✕</button>
    </div>
    <div class="bb-palette-grid">
      <div class="bb-palette-item current">1</div>
    </div>
    <div class="bb-palette-legend">
      <span><span class="legend-dot answered"></span> Answered</span>
      <span><span class="legend-dot marked"></span> Marked</span>
      <span><span class="legend-dot unanswered"></span> Unanswered</span>
    </div>
  </div>
</div>
<% } %>
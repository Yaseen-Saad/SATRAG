<% title = 'Adaptive Practice'; %>
<h1>Adaptive Practice</h1>
<p style="color:var(--text-muted);margin-bottom:1.5rem;">Questions personalized to your weak areas</p>

<% if (typeof error !== 'undefined' && error) { %>
<div class="flash flash-error"><%= error %></div>
<% } %>

<div class="adaptive-layout">
  <div class="adaptive-sidebar">
    <h3>Your Weak Topics</h3>
    <% if (weakTopics.length === 0) { %>
    <p style="color:var(--text-muted);font-size:0.9rem;">Answer more questions to unlock personalized recommendations.</p>
    <% } %>
    <% weakTopics.forEach(function(t) { %>
    <div class="topic-stat-card">
      <div class="topic-stat-header">
        <span class="topic-name"><%= t.topic %></span>
        <span class="topic-accuracy <%= t.accuracy_pct < 50 ? 'accuracy-low' : 'accuracy-mid' %>"><%= Math.round(t.accuracy_pct) %>%</span>
      </div>
      <div class="topic-stat-meta"><%= (t.subject === 'reading' || t.subject === 'writing') ? 'Reading & Writing' : t.subject %> · Band <%= t.current_difficulty_band %>/7</div>
      <div class="progress-bar"><div class="progress-fill" style="width: <%= Math.min(100, t.accuracy_pct) %>%"></div></div>
    </div>
    <% }) %>

    <form method="POST" action="/practice/adaptive/next" class="adaptive-form">
      <label for="subject">Focus Subject</label>
      <select name="subject" id="subject">
        <option value="">All Subjects</option>
        <option value="math" <%= subject === 'math' ? 'selected' : '' %>>Math</option>
        <option value="reading_writing" <%= subject === 'reading_writing' ? 'selected' : '' %>>Reading & Writing</option>
      </select>
      <button type="submit" class="btn btn--primary btn--block" style="margin-top:0.5rem">
        <%= question ? 'Get Next Question' : 'Start Adaptive Session' %>
      </button>
    </form>
  </div>

  <div class="adaptive-main">
    <% if (question) { %>
    <div class="adaptive-reason"><%= reason %></div>
    <div class="card" style="padding:1.5rem;">
      <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:1rem;">
        <span class="badge badge--<%= (question.subject === 'reading' || question.subject === 'writing') ? 'reading_writing' : (question.subject || '') %>"><%= (question.subject === 'reading' || question.subject === 'writing') ? 'Reading & Writing' : (question.subject || 'General') %></span>
        <span class="badge badge--<%= question.difficulty || '' %>">Band <%= question.difficulty_band || '?' %>/7</span>
        <% if (question.topic) { %><span class="badge badge-topic"><%= question.topic %></span><% } %>
      </div>
      <div style="margin-bottom:1rem;"><%- question.question_text || question.stem_plain_text || '' %></div>
      <% if (question.passage_text) { %>
      <div style="padding:0.75rem;background:var(--surface-2);border-radius:var(--radius-sm);margin-bottom:1rem;max-height:200px;overflow-y:auto;">
        <%- question.passage_text %>
      </div>
      <% } %>
      <% const qOpts = question.options || []; %>
      <% if (qOpts.length) { %>
      <div style="display:grid;gap:0.5rem;margin-bottom:1rem;">
        <% qOpts.forEach(function(opt, i) { %>
        <button class="bb-option" data-label="<%= opt.label || String.fromCharCode(65 + i) %>" onclick="window.selectOption && window.selectOption('<%= opt.label || String.fromCharCode(65 + i) %>')">
          <span class="bb-option-bubble"><%= opt.label || String.fromCharCode(65 + i) %></span>
          <span class="bb-option-text"><%- opt.content || opt.text || opt %></span>
        </button>
        <% }) %>
      </div>
      <% } %>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
        <a href="/practice/question/<%= question.id %>" class="btn btn--primary btn--sm">View Full Details</a>
        <form method="POST" action="/practice/adaptive/next" style="display:inline;">
          <input type="hidden" name="subject" value="<%= subject || '' %>">
          <button type="submit" class="btn btn--outline btn--sm">Next Question</button>
        </form>
      </div>
    </div>
    <% } else { %>
    <div class="adaptive-empty">
      <div class="empty-icon">&#128218;</div>
      <h3>Ready to Practice?</h3>
      <p>We'll find questions from your weakest areas to help you improve faster.</p>
    </div>
    <% } %>
  </div>
</div>

<% title = 'SATrack | Home'; %>
<section class="landing-hero">
  <h1 class="landing-headline">SAT Prep Tool That <br> Actually Sticks</h1>
  <p class="landing-sub">Mnemonics you'll remember. Questions that adapt to you. Progress you can see. No subscriptions, no paywalls. 100% Free for students.</p>
  <div class="landing-cta">
    <a href="/auth/signup" class="btn-primary btn-lg">Start Studying Free</a>
    <a href="/vocab" class="btn-secondary btn-lg">Browse Words</a>
  </div>

</section>

<section class="social-proof">
  <div class="social-proof-stats">
    <div class="stat-block">
      <div class="stat-number">400</div>
      <div class="stat-label">Words Generated</div>
    </div>
    <div class="stat-block">
      <div class="stat-number">15</div>
      <div class="stat-label">Questions Answered</div>
    </div>
    <div class="stat-block">
      <div class="stat-number">0</div>
      <div class="stat-label">Active Students</div>
    </div>
  </div>
</section>
<div class="card" style="text-align:center;">
  <h2 style="margin-top:0;">Ready to Start?</h2>
  <p style="color:var(--text-muted);">Enter a word to see its vocabulary entry, or jump straight into a quiz.</p>
  <div class="flex gap-1 justify-center" style="margin-top:1.25rem;">
    <form method="GET" action="/vocab" class="flex gap-1" style="max-width:400px; width:100%;">
      <input type="text" name="word" placeholder="e.g., perspicacious" class="flex-1">
      <button type="submit" class="btn-primary">Search</button>
    </form>
  </div>
</div>
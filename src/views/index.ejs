<% title = 'SAT Study Buddy'; %>
<div style="text-align:center; padding:2rem 0;">
  <h1 style="font-size:2.5rem; margin-bottom:0.5rem;">SAT Study Buddy</h1>
  <p style="color:#666; font-size:1.1rem; margin-bottom:2rem;">Build your SAT vocabulary with AI-powered mnemonics, quizzes, and spaced repetition.</p>
</div>

<div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap:1.5rem; margin-bottom:2rem;">
  <a href="/vocab" style="display:block; background:white; border:1px solid #ddd; border-radius:12px; padding:2rem; text-decoration:none; color:#333; text-align:center; box-shadow:0 2px 8px rgba(0,0,0,0.06); transition:transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 4px 16px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
    <div style="font-size:2.5rem; margin-bottom:0.75rem;">📖</div>
    <h2 style="margin:0 0 0.5rem;">Vocabulary</h2>
    <p style="color:#666; margin:0;">Generate Gulotta-style entries with mnemonics and picture stories for any SAT word.</p>
  </a>
  <a href="/quiz/start" style="display:block; background:white; border:1px solid #ddd; border-radius:12px; padding:2rem; text-decoration:none; color:#333; text-align:center; box-shadow:0 2px 8px rgba(0,0,0,0.06); transition:transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 4px 16px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
    <div style="font-size:2.5rem; margin-bottom:0.75rem;">🧠</div>
    <h2 style="margin:0 0 0.5rem;">Quizzes</h2>
    <p style="color:#666; margin:0;">Test your knowledge with AI-generated multiple-choice questions and spaced repetition.</p>
  </a>
  <a href="/dashboard" style="display:block; background:white; border:1px solid #ddd; border-radius:12px; padding:2rem; text-decoration:none; color:#333; text-align:center; box-shadow:0 2px 8px rgba(0,0,0,0.06); transition:transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 4px 16px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
    <div style="font-size:2.5rem; margin-bottom:0.75rem;">📊</div>
    <h2 style="margin:0 0 0.5rem;">Dashboard</h2>
    <p style="color:#666; margin:0;">Track your progress, review due words, and see your latest quiz scores.</p>
  </a>
</div>

<div style="background:white; border:1px solid #ddd; border-radius:12px; padding:2rem; text-align:center;">
  <h2 style="margin-top:0;">Ready to Start?</h2>
  <p style="color:#666;">Enter a word to generate a vocabulary entry, or jump straight into a quiz.</p>
  <div style="display:flex; gap:1rem; justify-content:center; margin-top:1.5rem;">
    <form method="GET" action="/vocab" style="display:flex; gap:0.5rem; max-width:400px;">
      <input type="text" name="word" placeholder="e.g., perspicacious" style="padding:0.75rem; border:2px solid #1a1a2e; border-radius:8px; font-size:1rem; flex:1;">
      <button type="submit" style="padding:0.75rem 1.5rem; background:#1a1a2e; color:white; border:none; border-radius:8px; cursor:pointer; font-size:1rem;">Search</button>
    </form>
  </div>
</div>
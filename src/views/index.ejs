<% title = 'SAT Study Buddy | Home'; %>
<section class="hero">
  <div class="hero-badge">SAT Prep, Reimagined</div>
  <h1>Your AI-Powered SAT Study Buddy</h1>
  <p>Generate Vocabulary mnemonics, test yourself with smart quizzes, and track your progress — all in one place.</p>
  <div class="hero-actions">
    <a href="/auth/signup" class="btn-primary btn-lg">Get Started Free</a>
    <a href="/vocab" class="btn-outline btn-lg">Browse Words</a>
  </div>
</section>
<div class="feature-grid">
  <a href="/vocab" class="card card-link" style="text-decoration:none;">
    <span class="feature-icon">&#128214;</span>
    <h3>Vocabulary Builder</h3>
    <p>Generate authentic entries with mnemonics, picture stories, and example sentences for any SAT word</p>
  </a>
  <a href="/practice" class="card card-link" style="text-decoration:none;">
    <span class="feature-icon">&#9997;</span>
    <h3>Smart Quizzes</h3>
    <p>Test your knowledge with AI-generated multiple-choice questions and spaced repetition.</p>
  </a>
  <a href="/dashboard" class="card card-link" style="text-decoration:none;">
    <span class="feature-icon">&#128200;</span>
    <h3>Progress Tracking</h3>
    <p>Track your progress, review due words, and see your latest quiz scores.</p>
  </a>
</div>
<div class="card" style="text-align:center;">
  <h2 style="margin-top:0;">Ready to Start?</h2>
  <p style="color:var(--text-muted);">Enter a word to see its vocabulary entry, or jump straight into a quiz.</p>
  <div class="flex gap-1 justify-center" style="margin-top:1.25rem;">
    <form method="GET" action="/vocab" class="flex gap-1" style="max-width:400px; width:100%;">
      <input type="text" name="word" placeholder="e.g., perspicacious" class="flex-1">
      <button type="submit" class="btn-primary">Search</button>
    </form>
  </div>
</div>
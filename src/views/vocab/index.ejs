<!-- Some AI Generated Interface -->
<% title = 'SAT Vocabulary Generator'; %>
<h1>SAT Study Buddy</h1>
<p style="color:#666; margin-bottom:2rem;">Enter any word to get a Gulotta-style vocabulary entry, or try a quiz.</p>

<% if (typeof error !== 'undefined' && error) { %>
<div style="background:#ffebee; color:#c62828; padding:0.75rem; border-radius:4px; margin-bottom:1rem;"><%= error %></div>
<% } %>

<div style="background:#f5f5f5; padding:1.5rem; border-radius:8px; margin-bottom:2rem;">
  <form method="POST" action="/vocab/generate" style="display:flex; gap:0.5rem;">
    <input type="text" name="word" placeholder="Enter a word (e.g., perspicacious)" required style="flex:1; padding:0.75rem; border:2px solid #1a1a2e; border-radius:4px; font-size:1rem;">
    <button type="submit" style="padding:0.75rem 1.5rem; background:#1a1a2e; color:white; border:none; border-radius:4px; cursor:pointer; font-size:1rem;">
      Generate
    </button>
  </form>
</div>

<div style="display:flex; gap:1rem; margin-bottom:2rem;">
  <a href="/quiz/start" style="flex:1; text-align:center; padding:1rem; background:#16213e; color:white; text-decoration:none; border-radius:8px;">Take a Quiz</a>
</div>

<% if (typeof recent !== 'undefined' && recent.length > 0) { %>
<h2>Recent Words</h2>
<div style="display:grid; gap:0.5rem;">
  <% recent.forEach(entry => { %>
  <a href="/vocab/<%= entry.word %>" style="display:block; padding:0.75rem; background:white; border:1px solid #ddd; border-radius:4px; text-decoration:none; color:#333;">
    <strong><%= entry.word %></strong> — <%= entry.definition?.substring(0, 80) %><%= entry.definition?.length > 80 ? '...' : '' %>
  </a>
  <% }) %>
</div>
<% } %>
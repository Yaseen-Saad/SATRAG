<% title = 'SAT Vocabulary Generator'; %>
<h1>SAT Study Buddy</h1>
<p style="color:#666; margin-bottom:2rem;">Enter any word to get a Gulotta-style vocabulary entry, or try a quiz.</p>

<% if (error) { %>
<div class="flash-error"><%= error %></div>
<% } %>

<div class="card" style="margin-bottom:2rem;">
  <form method="POST" action="/vocab/generate" style="display:flex; gap:0.5rem;">
    <input type="text" name="word" placeholder="Enter a word (e.g., perspicacious)" required class="form-input" style="flex:1;">
    <button type="submit" class="btn-primary">Generate</button>
  </form>
</div>

<div style="display:flex; gap:1rem; margin-bottom:2rem;">
  <a href="/vocab/lists" class="btn-secondary" style="flex:1; text-align:center;">My Word Lists</a>
</div>
<div style="display:flex; gap:1rem; margin-bottom:2rem;">
  <a href="/vocab/lists" class="btn-secondary" style="flex:1; text-align:center;">Word Lists</a>
</div>
<% if (recent && recent.length > 0) { %>
<h2>Recent Words</h2>
<div style="display:grid; gap:0.5rem;">
  <% recent.forEach(entry => { %>
  <a href="/vocab/<%= entry.word %>" class="word-list-item">
    <strong><%= entry.word %></strong> — <%= entry.definition?.substring(0, 80) %><%= entry.definition?.length > 80 ? '...' : '' %>
  </a>
  <% }) %>
</div>
<% } %>
<% title = 'Regenerate ' + word; %>
<h1>Regenerate "<%= word %>"</h1>
<p>Help improve the system by telling us what went wrong.</p>

<div class="card" style="max-width:600px;">
  <form action="/vocab/regenerate" method="POST" data-loading>
    <input type="hidden" name="word" value="<%= word %>">

    <div class="form-group">
      <label for="reason">Why are you regenerating?</label>
      <select name="reason" id="reason" class="form-input" required>
        <option value="confusing_mnemonic">Mnemonic was confusing</option>
        <option value="incorrect_definition">Definition was incorrect</option>
        <option value="boring_picture">Picture story was boring</option>
        <option value="poor_example">Example sentence was poor</option>
        <option value="low_quality">Overall quality was low</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div class="form-group">
      <label for="specificIssue">Specific issue</label>
      <textarea name="specificIssue" id="specificIssue" rows="3" class="form-input"></textarea>
    </div>

    <div class="form-group">
      <label for="improvements">Improvement suggestions</label>
      <textarea name="improvements" id="improvements" rows="3" class="form-input"></textarea>
    </div>

    <div class="form-group">
      <label for="partOfSpeech">Part of speech</label>
      <select name="partOfSpeech" id="partOfSpeech" class="form-input">
        <option value="noun">Noun</option>
        <option value="verb">Verb</option>
        <option value="adjective">Adjective</option>
        <option value="adverb">Adverb</option>
      </select>
    </div>

    <button type="submit" class="btn-warning">Regenerate</button>
    <a href="/vocab/<%= word %>" style="margin-left:0.5rem; color:#666;">Cancel</a>
  </form>
</div>

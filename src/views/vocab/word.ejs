<% title = entry.word; %>
<% if (typeof error !== 'undefined' && error) { %>
<div style="background:#ffebee; color:#c62828; padding:0.75rem; border-radius:4px; margin-bottom:1rem;"><%= error %></div>
<% } %>

<div style="background:white; border:1px solid #ddd; border-radius:8px; padding:1.5rem;">
  <h1 style="margin:0 0 0.25rem;"><%= entry.word %></h1>
  <p style="color:#666; margin:0 0 0.5rem;">
    <em><%= entry.pronunciation %></em> <strong><%= entry.part_of_speech %></strong>
  </p>

  <div style="background:#f5f5f5; padding:1rem; border-radius:4px; margin:1rem 0;">
    <p style="font-size:1.1rem; margin:0;"><%= entry.definition %></p>
  </div>

  <% if (entry.mnemonic_phrase) { %>
  <div style="margin:1rem 0;">
    <strong style="color:#1a1a2e;">Sounds like:</strong>
    <p style="margin:0.25rem 0;"><%= entry.mnemonic_phrase %></p>
  </div>
  <% } %>

  <% if (entry.picture_story) { %>
  <div style="margin:1rem 0;">
    <strong style="color:#1a1a2e;">Picture:</strong>
    <p style="margin:0.25rem 0;"><%= entry.picture_story %></p>
  </div>
  <% } %>

  <% if (entry.other_forms) { %>
  <div style="margin:1rem 0;">
    <strong style="color:#1a1a2e;">Other forms:</strong>
    <p style="margin:0.25rem 0;"><%= entry.other_forms %></p>
  </div>
  <% } %>

  <div style="margin:1rem 0; padding:0.75rem; background:#e8eaf6; border-radius:4px;">
    <strong style="color:#1a1a2e;">Example:</strong>
    <p style="margin:0.25rem 0; font-style:italic;"><%= entry.example_sentence %></p>
  </div>

  <% if (!entry.validation_passed) { %>
  <div style="background:#fff3e0; padding:0.5rem; border-radius:4px; margin:1rem 0;">
    ⚠️ This entry may need improvement. Try regenerating.
  </div>
  <% } %>

  <p style="color:#999; font-size:0.85rem; margin-top:1rem;">
    Source: <%= entry.source %> | Quality: <%= entry.quality_score %>/10
  </p>

  <div style="margin-top:1.5rem; display:flex; gap:0.5rem;">
    <a href="/vocab" style="padding:0.5rem 1rem; background:#1a1a2e; color:white; text-decoration:none; border-radius:4px;">New Word</a>
    <a href="/vocab/generate/<%= entry.word %>" style="padding:0.5rem 1rem; background:#ff8f00; color:white; text-decoration:none; border-radius:4px;">Regenerate</a>
    <a href="/quiz/start?word=<%= entry.word %>" style="padding:0.5rem 1rem; background:#16213e; color:white; text-decoration:none; border-radius:4px;">Quiz Me</a>
  </div>
</div>
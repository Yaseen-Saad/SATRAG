<% title = entry.word; %>
<% if (typeof error !== 'undefined' && error) { %>
<div class="flash flash-error"><%= error %></div>
<% } %>

<div class="entry-card">
  <div class="entry-word"><%= entry.word %></div>
  <div class="entry-meta">
    <em><%= entry.pronunciation %></em> <strong><%= entry.part_of_speech %></strong>
  </div>

  <div class="entry-definition">
    <p style="margin:0;"><%= entry.definition %></p>
  </div>

  <% if (entry.mnemonic_phrase) { %>
  <div class="entry-section">
    <div class="section-label">Sounds like:</div>
    <p style="margin:0.25rem 0 0;"><%= entry.mnemonic_phrase %></p>
  </div>
  <% } %>

  <% if (entry.picture_story) { %>
  <div class="entry-section">
    <div class="section-label">Picture:</div>
    <p style="margin:0.25rem 0 0;"><%= entry.picture_story %></p>
  </div>
  <% } %>

  <% if (entry.other_forms) { %>
  <div class="entry-section">
    <div class="section-label">Other forms:</div>
    <p style="margin:0.25rem 0 0;"><%= entry.other_forms %></p>
  </div>
  <% } %>

  <div class="entry-section">
    <div class="section-label">Example:</div>
    <p style="margin:0.25rem 0 0; font-style:italic;"><%= entry.example_sentence %></p>
  </div>

  <% if (!entry.validation_passed) { %>
  <div class="flash flash-info" style="margin-top:1rem;">This entry may need improvement. Try regenerating.</div>
  <% } %>

  <div class="entry-footer">
    <span>Source: <%= entry.source %></span>
    <span>Quality: <%= entry.quality_score %>/10</span>
  </div>

  <div class="entry-actions">
    <a href="/vocab" class="btn-primary">New Word</a>
    <a href="/vocab/generate/<%= entry.word %>" class="btn-warning">Regenerate</a>
    <a href="/vocab/lists" class="btn-secondary">My Lists</a>
 <form method="POST" action="/flashcards/word/<%= entry.id %>/add" style="display:inline;" class="flashcard-add-form">
  <button type="submit" class="btn btn-outline btn-sm">Add to Flashcards</button>
</form>
<script>
  document.querySelector('.flashcard-add-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = this.querySelector('button');
    btn.textContent = 'Adding...';
    fetch(this.action, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(d) { btn.textContent = d.success ? 'Added!' : 'Error'; })
      .catch(function() { btn.textContent = 'Error'; });
  });
</script>
  </div>
  <div style="margin-top:1rem; padding:0.75rem; border:1px solid var(--border); border-radius:8px;">
    <form method="POST" action="/vocab/lists/add" style="display:flex; gap:0.5rem; align-items:center;">
      <input type="hidden" name="wordId" value="<%= entry.id %>">
      <select name="listId" style="flex:1; padding:0.4rem; border:1px solid var(--border); border-radius:4px;">
        <option value="new">Add to List...</option>
        <% if (typeof lists !== 'undefined' && lists) {lists.forEach(l=>{ %>
        <option value="<%= l.id %>"><%= l.name %> (<%= l.word_count?.[0]?.count ?? l.word_count ?? 0 %>)</option>
        <% })}%>
      </select>
      <button type="submit" class="btn-primary" onclick="const sel=this.form.listId; if(sel.value==='new'||!sel.value){window.location='/vocab/lists';return false;} this.form.action='/vocab/lists/'+sel.value+'/add'">Add</button>
      <a href="/vocab/lists" style="font-size:0.85rem" class="btn-secondary">New List</a>
    </form>
  </div>
  <% if (typeof isGenerated !== 'undefined' && isGenerated) { %>
  <div class="entry-section" style="margin-top:1.5rem;">
    <div class="section-label">How was this entry?</div>
    <form action="/feedback/submit" method="POST" style="margin-top:0.5rem;">
      <input type="hidden" name="wordId" value="<%= entry.id %>">
      <div style="display:flex; gap:0.25rem; align-items:center; flex-wrap:wrap;">
        <% for (let i = 1; i <= 10; i++) { %>
        <label style="cursor:pointer; padding:0.25rem 0.5rem; border:1px solid var(--border); border-radius:4px; font-size:0.85rem;">
          <input type="radio" name="satisfaction" value="<%= i %>" <%= i === 7 ? 'checked' : '' %> style="margin:0;"> <%= i %>
        </label>
        <% } %>
      </div>
      <div style="margin-top:0.5rem; display:flex; gap:0.5rem;">
        <button type="submit" class="btn-primary" style="font-size:0.85rem;">Submit Rating</button>
      </div>
    </form>
  </div>
  <% } %>
</div>
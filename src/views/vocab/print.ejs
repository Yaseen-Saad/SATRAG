<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title><%= list.name %> — Study Sheet</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Georgia', serif;
      padding: 2rem;
      color: #222;
    }

    .sheet-header {
      text-align: center;
      margin-bottom: 2rem;
      border-bottom: 2px solid #333;
      padding-bottom: 1rem;
    }

    .sheet-header h1 {
      font-size: 1.8rem;
    }

    .sheet-header p {
      color: #666;
      margin-top: 0.25rem;
    }

    .word-entry {
      margin-bottom: 1.5rem;
      padding: 1rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      page-break-inside: avoid;
    }

    .word-title {
      font-size: 1.3rem;
      font-weight: bold;
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }

    .word-pron {
      font-size: 0.9rem;
      color: #666;
      font-style: italic;
    }

    .word-pos {
      font-size: 0.8rem;
      color: #888;
      background: #f0f0f0;
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
    }

    .word-section {
      margin-top: 0.5rem;
    }

    .word-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #999;
      font-weight: bold;
    }

    .word-text {
      margin-top: 0.15rem;
    }

    .mnemonic-box {
      background: #fff8e1;
      border-left: 3px solid #ffc107;
      padding: 0.5rem 0.75rem;
      margin-top: 0.5rem;
    }

    .example-box {
      background: #f3f4ff;
      border-left: 3px solid #3f51b5;
      padding: 0.5rem 0.75rem;
      margin-top: 0.5rem;
      font-style: italic;
    }

    .footer {
      text-align: center;
      margin-top: 2rem;
      font-size: 0.8rem;
      color: #999;
    }

    @media print {
      body {
        padding: 1rem;
      }

      .no-print {
        display: none;
      }
    }
  </style>
</head>

<body>
  <div class="no-print" style="text-align:center; margin-bottom:1rem;">
    <button onclick="window.print()" style="padding:0.5rem 1.5rem; font-size:1rem; cursor:pointer;">Print Study Sheet</button>
    <a href="/vocab/lists/<%= list.id %>" style="margin-left:1rem;">Back to List</a>
  </div>

  <div class="sheet-header">
    <h1><%= list.name %></h1>
    <p><%= words.length %> words · Study Sheet</p>
  </div>

  <% words.forEach(function(w) { %>
  <div class="word-entry">
    <div class="word-title">
      <%= w.word %>
      <% if (w.pronunciation) { %><span class="word-pron"><%= w.pronunciation %></span><% } %>
      <% if (w.part_of_speech) { %><span class="word-pos"><%= w.part_of_speech %></span><% } %>
    </div>
    <div class="word-section">
      <div class="word-label">Definition</div>
      <div class="word-text"><%= w.definition %></div>
    </div>
    <% if (w.mnemonic_phrase) { %>
    <div class="mnemonic-box">
      <div class="word-label"><%= w.mnemonic_type || 'Mnemonic' %></div>
      <div class="word-text"><%= w.mnemonic_phrase %></div>
    </div>
    <% } %>
    <% if (w.example_sentence) { %>
    <div class="example-box">
      <div class="word-label">Example</div>
      <div class="word-text"><%= w.example_sentence %></div>
    </div>
    <% } %>
  </div>
  <% }); %>

  <div class="footer">Generated by SAT Study Buddy</div>
</body>

</html>
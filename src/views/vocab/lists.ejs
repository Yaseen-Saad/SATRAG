<% title = 'Word Lists'; %>
<div class="dashboard">
  <div class="dash-header">
    <h1>Word Lists</h1>
    <p class="dash-subtitle">Browse system lists or create your own</p>
  </div>
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="flash flash-error"><%= error %><button class="dismiss" onclick="this.parentElement.remove()">×</button></div>
  <% } %>

  <div class="dash-card" style="margin-bottom:1.5rem">
    <div class="dash-card-header">
      <h2>Create New List</h2>
    </div>
    <div class="dash-card-body">
      <form method="POST" action="/vocab/lists" class="vocab-create-form">
        <div class="form-group"><input type="text" name="name" placeholder="List name" required></div>
        <div class="form-group"><input type="text" name="description" placeholder="Description"></div>
        <div class="form-group">
          <select name="visibility">
            <option value="private">Private</option>
            <option value="public">Public</option>
          </select>
        </div>
        <button type="submit" class="btn-primary btn-sm">Create</button>
      </form>
    </div>
  </div>

  <!-- Tabs -->
  <div class="vocab-list-tabs">
    <% ['mine','system','public','shared'].forEach(function(t) { %>
    <a href="/vocab/lists?tab=<%= t %>" class="vocab-list-tab <%= tab === t ? 'active' : '' %>">
      <%= {mine:'My Lists', system:'System', public:'Public', shared:'Shared With Me'}[t] %>
    </a>
    <% }) %>
  </div>

  <%
    let currentLists = [];
    let emptyMsg = '';
    if (tab === 'mine') { currentLists = myLists || []; emptyMsg = 'You haven\'t created any lists yet.'; }
    else if (tab === 'system') { currentLists = systemLists || []; emptyMsg = 'No system lists available.'; }
    else if (tab === 'public') { currentLists = publicLists || []; emptyMsg = 'No public lists yet.'; }
    else if (tab === 'shared') { currentLists = sharedLists || []; emptyMsg = 'No lists shared with you yet.'; }
  %>

  <% if (currentLists.length === 0) { %>
  <div class="card vocab-list-empty">
    <p><%= emptyMsg %></p>
    <% if (tab === 'mine') { %><p style="font-size:0.9rem;">Go to any word page to start building.</p><% } %>
  </div>
  <% } else { %>
  <div class="dash-card">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Words</th>
          <th>Visibility</th>
          <th>By</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% currentLists.forEach(function(l) { %>
        <tr>
          <td><a href="/vocab/lists/<%= l.id %>" style="font-weight:bold;"><%= l.name %></a></td>
          <td><%= l.word_count?.[0]?.count ?? l.word_count ?? 0 %></td>
          <td><%= l.visibility %><%= l.cloned_from ? ' (clone)' : '' %></td>
          <td><%= l.created_by ? (l.created_by === (typeof user !== 'undefined' && user ? user.id : '') ? 'me' : l.created_by.slice(0,8)) : 'system' %></td>
          <td>
            <% if (tab !== 'mine') { %>
            <form method="POST" action="/vocab/lists/<%= l.id %>/clone" style="display:inline;">
              <button type="submit" class="btn-outline btn-sm">Clone</button>
            </form>
            <% } %>
            <% if (typeof user !== 'undefined' && user && l.created_by === user.id) { %>
            <form method="POST" action="/vocab/lists/<%= l.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this list?')">
              <button type="submit" class="btn-danger btn-sm">Delete</button>
            </form>
            <% } %>
          </td>
          <td>
            <div class="list-actions" style="margin-bottom: 1rem;">
              <a href="/vocab/lists/<%= l.id %>/export?format=print" class="btn btn-outline btn-sm" target="_blank"> Print Study Sheet</a>
              <a href="/vocab/lists/<%= l.id %>/export?format=csv" class="btn btn-outline btn-sm"> Download CSV</a>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
  <a href="/vocab" class="btn btn-outline" style="margin-top:1rem;">← Back to Vocabulary</a>
</div>
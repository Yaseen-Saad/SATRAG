<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title? title : 'SAT Study Buddy' %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/bluebook.css">
</head>

<body>
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/" class="navbar-brand">SAT Study Buddy</a>
      <button class="navbar-toggle" id="nav-toggle" aria-label="Menu">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
      <button id="theme-toggle" class="nav-link theme-btn">🌙</button>
      <div class="navbar-links" id="nav-links">
        <a href="/vocab" class="nav-link">Words</a>
        <a href="/practice" class="nav-link">Practice</a>
        <a href="/quiz/start" class="nav-link">Quiz</a>
        <% if (typeof user !== 'undefined' && user) { %>
        <a href="/dashboard" class="nav-link">Dashboard</a>
        <a href="/auth/logout" class="nav-link nav-link--signout">Sign Out</a>
        <% } else { %>
        <a href="/auth/login" class="nav-link">Log In</a>
        <a href="/auth/signup" class="btn btn--primary btn--sm">Sign Up</a>
        <% } %>
      </div>
    </div>
  </nav>
  <div class="overlay" id="overlay"></div>
  <main>
    <%- body %>
  </main>
  <script src="/js/app.js"></script>
  <script src="/js/bluebook.js"></script>
</body>

</html>
<% title = 'Error ' + statusCode; %>
<div class="dashboard" style="text-align:center; padding-top:var(--sp-20);">
  <div style="font-family:var(--font-mono); font-size:var(--text-6xl); font-weight:900; color:var(--color-text-muted); opacity:0.3; margin-bottom:var(--sp-4);"><%= statusCode %></div>
  <h1 style="font-size:var(--text-2xl); margin-bottom:var(--sp-2);"><%= error %></h1>
  <p style="color:var(--color-text-muted); margin-bottom:var(--sp-8);">Something went wrong. Head back home.</p>
  <a href="/" class="btn-primary">Go Home</a>
</div>
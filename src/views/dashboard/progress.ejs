<% title = 'Dashboard'; %>

<div class="dashboard">

  <!-- Header -->
  <div class="dash-header">
    <div>
      <h1>Dashboard</h1>
      <p class="dash-subtitle">
        <%= streak.currentStreak %>-day study streak ·
        <%= practiceStats.attempted || 0 %> questions answered
      </p>
    </div>
    <div class="dash-header-actions">
      <a href="/practice" class="btn btn-primary btn-sm">Practice</a>
      <a href="/quiz/start" class="btn btn-outline btn-sm">Take Quiz</a>
    </div>
  </div>

  <!-- Overview Stats -->
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-value" style="color:var(--teal)">
        <%= avgScore !== null ? avgScore + '%' : '—' %>
      </div>
      <div class="stat-label">Avg Quiz Score</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color:#d35400">
        <%= avgQualityScore !== null ? avgQualityScore : '—' %>
      </div>
      <div class="stat-label">Avg Quality</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color:var(--success)">
        <%= avgSatisfaction !== null ? avgSatisfaction : '—'  %>
      </div>
      <div class="stat-label">Satisfaction</div>
    </div>
  </div>

  <!-- Practice & Streak Row -->
  <div class="dash-row">
    <!-- Practice Stats -->
    <div class="dash-card dash-card--grow">
      <div class="dash-card-header">
        <h2>Practice Overview</h2>
        <a href="/practice" class="btn btn-ghost btn-sm">View All</a>
      </div>
      <div class="dash-card-body">
        <div class="mini-stat-grid">
          <div class="mini-stat">
            <div class="mini-stat-value"><%= practiceStats.attempted || 0 %></div>
            <div class="mini-stat-label">Attempted</div>
          </div>
          <div class="mini-stat">
            <div class="mini-stat-value" style="color:var(--success)">
              <%= practiceStats.correct || 0 %>
            </div>
            <div class="mini-stat-label">Correct</div>
          </div>
          <div class="mini-stat">
            <div class="mini-stat-value" style="color:<%= practiceStats.accuracy !== null ? (practiceStats.accuracy >= 70 ? 'var(--success)' : practiceStats.accuracy >= 40 ? 'var(--warning)' : 'var(--error)') : '#888' %>;">
              <%= practiceStats.accuracy !== null ? practiceStats.accuracy + '%' : '—' %>
            </div>
            <div class="mini-stat-label">Accuracy</div>
          </div>
          <div class="mini-stat">
            <div class="mini-stat-value" style="color:var(--warning)"><%= practiceStats.markedForReview || 0 %></div>
            <div class="mini-stat-label">Marked for Review</div>
          </div>
        </div>
        <!-- Accuracy progress bar -->
        <% if (practiceStats.accuracy !== null) { %>
        <div class="progress-bar">
          <div class="progress-fill" style="width:<%= practiceStats.accuracy %>%"></div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Streak Card -->
    <div class="dash-card dash-card--compact">
      <div class="dash-card-header">
        <h2>Streak</h2>
      </div>
      <div class="streak-display">
        <div class="streak-number"><%= streak.currentStreak %></div>
        <div class="streak-label">day streak</div>
        <div class="streak-longest">Best: <%= streak.longestStreak %> days</div>
      </div>
      <!-- Weekly mini-calendar -->
      <div class="week-grid">
        <% weeklyActivity.forEach(function(day) { %>
        <div class="week-cell" title="<%= day.date %>: <%= day.count %> questions" style="--intensity: <%= Math.min(1, day.count / 5) %>;">
          <span class="week-cell-label"><%= day.date.slice(5) %></span>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Topic Weak Spots -->
  <% if (topicBreakdown.length > 0) { %>
  <div class="dash-card">
    <div class="dash-card-header">
      <h2>Weakest Topics</h2>
      <a href="/practice" class="btn btn-ghost btn-sm">Practice These</a>
    </div>
    <div class="dash-card-body">
      <% weakestTopics.forEach(function(t) { %>
      <div class="topic-row">
        <div class="topic-info">
          <span class="topic-subject"><%= t.subject %></span>
          <span class="topic-name"><%= t.topic %></span>
        </div>
        <div class="topic-right">
          <span class="topic-accuracy" style="color:<%= t.accuracy < 50 ? 'var(--error)' : t.accuracy < 75 ? 'var(--warning)' : 'var(--success)' %>;">
            <%= t.accuracy %>%
          </span>
          <div class="topic-bar">
            <div class="topic-bar-fill" style="width:<%= t.accuracy %>%"></div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- Two-column bottom section -->
  <div class="dash-row">
    <!-- Recent Quizzes -->
    <div class="dash-card dash-card--grow">
      <div class="dash-card-header">
        <h2>Recent Quizzes</h2>
        <a href="/quiz/start" class="btn btn-ghost btn-sm">New Quiz</a>
      </div>
      <div class="dash-card-body">
        <% if (recentQuizzes.length === 0) { %>
        <p class="empty-state">No quizzes taken yet. <a href="/quiz/start">Start one</a></p>
        <% } else { %>
        <table>
          <tr>
            <th>Date</th>
            <th>Score</th>
            <th>Q's</th>
          </tr>
          <% recentQuizzes.forEach(function(q) { %>
          <tr>
            <td><%= new Date(q.attempt_time).toLocaleDateString() %></td>
            <td style="font-weight:bold; color:<%= q.score >= 70 ? 'var(--success)' : q.score >= 40 ? 'var(--warning)' : 'var(--error)' %>;">
              <%= q.score %>%
            </td>
            <td><%= q.total_questions %></td>
          </tr>
          <% }) %>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Recent Feedback -->
  <div class="dash-card">
    <div class="dash-card-header">
      <h2>Recent Feedback</h2>
    </div>
    <div class="dash-card-body">
      <% if (recentFeedback.length === 0) { %>
      <p class="empty-state">No feedback yet.</p>
      <% } else { %>
      <% recentFeedback.forEach(function(f) { %>
      <div class="feedback-row">
        <div class="feedback-left">
          <strong><%= f.word %></strong>
          <span class="feedback-rating" style="color:<%= f.satisfaction_score >= 7 ? 'var(--success)' : f.satisfaction_score >= 4 ? 'var(--warning)' : 'var(--error)' %>;">
            <%= f.satisfaction_score %>/10
          </span>
        </div>
        <% if (f.comments) { %>
        <div class="feedback-comment"><%= f.comments %></div>
        <% } %>
        <div class="feedback-date"><%= new Date(f.created_at).toLocaleDateString() %></div>
      </div>
      <% }) %>
      <% } %>
    </div>
  </div>

</div>
<% title = 'Dashboard'; %>
<h1>Dashboard</h1>

<div class="stat-grid">
  <div class="stat-card">
    <h3>Words Learned</h3>
    <div class="stat-value" style="color:#27ae60;"><%= wordsLearned %></div>
  </div>
  <div class="stat-card">
    <h3>Avg Quiz Score</h3>
    <div class="stat-value" style="color:#2980b9;"><%= avgScore !== null ? avgScore + '%' : 'N/A' %></div>
  </div>
  <div class="stat-card">
    <h3>Total Entries</h3>
    <div class="stat-value" style="color:#8e44ad;"><%= totalEntries %></div>
  </div>
  <div class="stat-card">
    <h3>Avg Quality</h3>
    <div class="stat-value" style="color:#d35400;"><%= avgQualityScore !== null ? avgQualityScore + '/10' : 'N/A' %></div>
  </div>
  <div class="stat-card">
    <h3>Avg Satisfaction</h3>
    <div class="stat-value" style="color:#16a085;"><%= avgSatisfaction !== null ? avgSatisfaction + '/10' : 'N/A' %></div>
  </div>
</div>

<h2>Due for Review</h2>
<% if (dueReviews.length === 0) { %>
  <p style="color:#888;">No words due for review.</p>
<% } else { %>
  <div style="display:grid; gap:0.5rem;">
    <% dueReviews.forEach(r => { %>
      <a href="/vocab/<%= r.vocab_entries.word %>" class="word-list-item">
        <strong><%= r.vocab_entries.word %></strong> — <%= r.vocab_entries.definition %>
      </a>
    <% }) %>
  </div>
<% } %>

<h2>Recent Quizzes</h2>
<% if (quizzes.length === 0) { %>
  <p style="color:#888;">No quizzes taken yet.</p>
<% } else { %>
  <table>
    <tr>
      <th>Date</th>
      <th>Score</th>
      <th>Questions</th>
    </tr>
    <% quizzes.forEach(q => { %>
      <tr>
        <td><%= new Date(q.attempt_time).toLocaleDateString() %></td>
        <td style="font-weight:bold; color: <%= q.score >= 70 ? '#27ae60' : q.score >= 40 ? '#f39c12' : '#e74c3c' %>;"><%= q.score %>%</td>
        <td><%= q.total_questions %></td>
      </tr>
    <% }) %>
  </table>
<% } %>

<h2>Recent Feedback</h2>
<% if (recentFeedback.length === 0) { %>
  <p style="color:#888;">No feedback yet.</p>
<% } else { %>
  <% recentFeedback.forEach(f => { %>
    <div class="card" style="margin-bottom:0.5rem;">
      <strong><%= f.word %></strong> — Rating: <%= f.satisfaction_score %>/10
      <% if (f.comments) { %><p style="margin-top:0.25rem; color:#666;"><%= f.comments %></p><% } %>
      <small style="color:#999;"><%= new Date(f.created_at).toLocaleDateString() %></small>
    </div>
  <% }) %>
<% } %>

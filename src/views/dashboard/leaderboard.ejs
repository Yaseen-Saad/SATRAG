<% title = 'Leaderboard'; %>

<div class="dashboard">
  <div class="dash-header">
    <div>
      <h1>Leaderboard</h1>
      <p class="dash-subtitle">
        <%= totalCount %> participants
        <% if (userRank) { %> · You are #<%= userRank %><% } %>
      </p>
    </div>
    <div class="dash-header-actions">
      <a href="/dashboard" class="btn btn-outline btn-sm">Dashboard</a>
      <a href="/practice" class="btn btn-primary btn-sm">Practice</a>
    </div>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="flash flash-error"><%= error %></div>
  <% } %>

  <div class="dash-card" style="margin-bottom:1rem;">
    <form id="leaderboard-filters" style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
      <label style="font-size:0.85rem;color:var(--text-muted);">Filter by grade:</label>
      <select id="grade-filter" onchange="applyFilters()" style="padding:0.4rem 0.6rem;border:1px solid var(--border);border-radius:6px;font-size:0.85rem;background:var(--surface);color:var(--text);">
        <option value="">All Grades</option>
        <option value="9" <%= grade === '9' ? 'selected' : '' %>>9th</option>
        <option value="10" <%= grade === '10' ? 'selected' : '' %>>10th</option>
        <option value="11" <%= grade === '11' ? 'selected' : '' %>>11th</option>
        <option value="12" <%= grade === '12' ? 'selected' : '' %>>12th</option>
        <option value="Gap Year" <%= grade === 'Gap Year' ? 'selected' : '' %>>Gap Year</option>
      </select>
    </form>
  </div>

  <% if (entries.length === 0) { %>
  <div class="card" style="text-align:center; padding:3rem;">
    <p style="font-size:1.2rem; color:var(--text-muted);">No one has joined the leaderboard yet.</p>
    <a href="/settings" class="btn btn-outline btn-sm" style="margin-top:1rem;">Enable in Settings</a>
  </div>
  <% } else { %>
  <div class="dash-card">
    <table>
      <thead>
        <tr>
          <th style="width:50px;">Rank</th>
          <th>Name</th>
          <th>Grade</th>
          <th style="text-align:center;cursor:pointer;" onclick="toggleSort('correct')">Correct <%= sortBy === 'correct' ? (sortDir === 'desc' ? '↓' : '↑') : '' %></th>
          <th style="text-align:center;cursor:pointer;" onclick="toggleSort('accuracy')">Accuracy <%= sortBy === 'accuracy' ? (sortDir === 'desc' ? '↓' : '↑') : '' %></th>
          <th style="text-align:center;cursor:pointer;" onclick="toggleSort('score')">Score <%= sortBy === 'score' ? (sortDir === 'desc' ? '↓' : '↑') : '' %></th>
        </tr>
      </thead>
      <tbody>
        <% entries.forEach(function(e) { %>
        <tr style="<%= (user && e.userId === user.id) ? 'background:rgba(99,102,241,0.08); font-weight:600;' : '' %>">
          <td style="text-align:center;">
            <% if (e.rank === 1) { %><img src="/public/img/icon-gold-medal.svg" /><% } else if (e.rank === 2) { %><img src="/public/img/icon-silver-medal.svg" /><% } else if (e.rank === 3) { %><img src="/public/img/icon-bronze-medal.svg" /><% } else { %><%= e.rank %><% } %>
          </td>
          <td><%= e.name %></td>
          <td><%= e.grade %></td>
          <td style="text-align:center;"><%= e.correct %>/<%= e.total %></td>
          <td style="text-align:center; color:<%= e.accuracy >= 70 ? 'var(--success)' : e.accuracy >= 40 ? 'var(--warning)' : 'var(--error)' %>;">
            <%= e.accuracy %>%
          </td>
          <td style="text-align:center; font-weight:700; color:var(--indigo);"><%= e.score %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
  let currentSortBy = <%- JSON.stringify(sortBy).replace(/</g, '\\u003c') %>;
  let currentSortDir = <%- JSON.stringify(sortDir).replace(/</g, '\\u003c') %>;
  let currentGrade = <%- JSON.stringify(grade).replace(/</g, '\\u003c') %>;

  function toggleSort(col) {
    if (currentSortBy === col) {
      currentSortDir = currentSortDir === 'desc' ? 'asc' : 'desc';
    } else {
      currentSortBy = col;
      currentSortDir = 'desc';
    }
    applyFilters();
  }

  function applyFilters() {
    var grade = document.getElementById('grade-filter').value;
    var url = '/dashboard/leaderboard?sortBy=' + encodeURIComponent(currentSortBy) +
      '&sortDir=' + encodeURIComponent(currentSortDir);
    if (grade) url += '&grade=' + encodeURIComponent(grade);
    window.location.href = url;
  }
</script>
<% title='Settings' %>
<div class="dashboard">
  <div class="dash-header">
    <h1>Settings</h1>
    <p class="dash-subtitle">Manage your account and preferences</p>
  </div>
  <% if (typeof error !== 'undefined' && error){ %>
  <div class="flash flash-error"><%= error %><button class="dismiss" onclick="this.parentElement.remove()">×</button></div>
  <%}%>
  <% if (typeof success !== 'undefined' && success){ %>
  <div class="flash flash-success"><%= success %><button class="dismiss" onclick="this.parentElement.remove()">×</button></div>
  <% } %>
  <% if (typeof prompt !== 'undefined' && prompt === "complete-profile"){ %>
  <div class="flash flash-warning">Please complete your profile to access all features.<button class="dismiss" onclick="this.parentElement.remove()">×</button></div>
  <% }else if(typeof prompt !== 'undefined' && prompt==="complete-apikeys"){ %>
  <div class="flash flash-info">Set your LLM and Embeddings API Keys to unlock AI generation features.<button class="dismiss" onclick="this.parentElement.remove()">×</button></div>
  <% } %>

  <form action="/settings/update-all" method="POST" data-loading>
    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Profile</h2>
      </div>
      <div class="dash-card-body">
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName" value="<%= (profile && profile.first_name) || '' %>" required maxlength="100">
          </div>
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName" value="<%= (profile && profile.last_name) || '' %>" required maxlength="100">
          </div>
        </div>
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-top:0.75rem;">
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="<%= (profile && profile.email) || '' %>" readonly style="background:var(--surface-2);cursor:not-allowed;">
          </div>
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="school">School</label>
            <input type="text" id="school" name="school" value="<%= (profile && profile.school) || '' %>" required maxlength="200">
          </div>
        </div>
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-top:0.75rem;">
          <div class="form-group" style="flex:1;min-width:150px;">
            <label for="grade">Grade Level</label>
            <select id="grade" name="grade">
              <option value="">— Select —</option>
              <% ['9','10','11','12','Gap Year','Other','I am not a student'].forEach(function(g) { %>
              <option value="<%= g %>" <%= (profile && profile.grade === g) ? 'selected' : '' %>><%= g %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="flex:1;min-width:150px;">
            <label for="gender">Gender</label>
            <select id="gender" name="gender">
              <option value="">— Select —</option>
              <option value="male" <%= (profile && profile.gender === 'male') ? 'selected' : '' %>>Male</option>
              <option value="female" <%= (profile && profile.gender === 'female') ? 'selected' : '' %>>Female</option>
            </select>
          </div>
          <div class="form-group" style="flex:1;min-width:150px;">
            <label for="birthdate">Birthdate</label>
            <input type="date" id="birthdate" name="birthdate" value="<%= (profile && profile.birthdate) || '' %>">
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>API Keys</h2>
      </div>
      <div class="dash-card-body">
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
          <div class="form-group" style="flex:1;min-width:250px;">
            <label for="llmKey">LLM API Key</label>
            <input type="password" id="llmKey" name="llmKey" placeholder="<%= (profile && profile.llm_apikey) ? '••••••••••••' : 'Enter your API key' %>">
          </div>
          <div class="form-group" style="flex:1;min-width:250px;">
            <label for="embeddingKey">Embedding API Key</label>
            <input type="password" id="embeddingKey" name="embeddingKey" placeholder="<%= (profile && profile.embedding_apikey) ? '••••••••••••' : 'Enter your API key' %>">
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Avatar</h2>
      </div>
      <div class="dash-card-body">
        <div style="display:flex; gap:1rem; align-items:center; flex-wrap:wrap;">
          <div style="text-align:center;">
            <img src="<%= (profile && profile.avatar_url) || '' %>" alt="Avatar" id="avatar-preview" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid var(--border);background:var(--surface-3);" onerror="this.style.display='none'">
          </div>
          <div style="flex:1;min-width:250px;">
            <div class="form-group" style="margin:0 0 0.5rem;">
              <label>Upload Image</label>
              <form action="/settings/avatar/upload" method="POST" enctype="multipart/form-data" id="avatar-upload-form" style="display:flex;gap:0.5rem;">
                <input type="file" name="avatar" accept="image/png,image/jpeg,image/gif,image/webp" required style="flex:1;font-size:0.85rem;">
                <button type="submit" class="btn-primary btn-sm">Upload</button>
              </form>
            </div>
            <div class="form-group" style="margin:0;">
              <label for="avatarUrl">Or paste image URL</label>
              <input type="url" id="avatarUrl" name="avatarUrl" placeholder="https://example.com/avatar.jpg" value="<%= (profile && profile.avatar_url) || '' %>" oninput="document.getElementById('avatar-preview').src=this.value||'';document.getElementById('avatar-preview').style.display='block'">
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Preferences</h2>
      </div>
      <div class="dash-card-body">
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:end;">
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="referral">How did you hear about us?</label>
            <select id="referral" name="referral">
              <option value="">— Select —</option>
              <% ['friend','socialmedia','school','teacher','other'].forEach(function(r) { %>
              <option value="<%= r %>" <%= (profile && profile.referral === r) ? 'selected' : '' %>><%= r.charAt(0).toUpperCase() + r.slice(1) %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="leaderboardstatus">Leaderboard</label>
            <select id="leaderboardstatus" name="leaderboardstatus">
              <option value="enabled" <%= (!profile || profile.participate_in_leaderboard !== false) ? 'selected' : '' %>>Enabled</option>
              <option value="disabled" <%= (profile && profile.participate_in_leaderboard === false) ? 'selected' : '' %>>Disabled</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Account Info</h2>
      </div>
      <div class="dash-card-body">
        <div class="mini-stat-grid">
          <div class="mini-stat">
            <div class="mini-stat-value"><%= (profile && profile.first_login) ? new Date(profile.first_login).toLocaleDateString() : '—' %></div>
            <div class="mini-stat-label">Member Since</div>
          </div>
          <div class="mini-stat">
            <div class="mini-stat-value"><%= (profile && profile.last_login) ? new Date(profile.last_login).toLocaleDateString() : '—' %></div>
            <div class="mini-stat-label">Last Login</div>
          </div>
        </div>
        <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);font-size:0.9rem;color:var(--text-muted);">
          <strong>Model:</strong> <%= process.env.LLM_MODEL || 'Default' %><br>
          <strong>LLM Key:</strong> <%= (profile && profile.llm_apikey) ? '✓ Set' : '✗ Not set' %><br>
          <strong>Embed Key:</strong> <%= (profile && profile.embedding_apikey) ? '✓ Set' : '✗ Not set' %>
        </div>
      </div>
    </div>

    <div style="margin-top:1.5rem; text-align:right;">
      <button type="submit" class="btn-primary btn-lg">Save All Settings</button>
    </div>
  </form>
</div>
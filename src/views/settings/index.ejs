<% title='Settings' %>
<div class="dashboard">
  <div class="dash-header">
    <h1>Settings</h1>
    <p class="dash-subtitle">Manage your account and preferences</p>
  </div>
  <% if (typeof error !== 'undefined' && error){ %>
  <div class="flash flash-error"><%=error%><button class="dismiss" onclick="this.parentElement.remove()">Dismiss</button></div>
  <%}%>
<% if (typeof success !== 'undefined' && success){ %>
  <div class="flash flash-success"><%=success%><button class="dismiss" onclick="this.parentElement.remove()">Dismiss</button></div>
  <% } %>
  <% if (prompt === "complete_profile"){ %>
  <div class="flash flash-warning">Please complete your profile to access all features.<button class="dismiss" onclick="this.parentElement.remove()">Dismiss</button></div>
  <% }else if(prompt==="api_keys"){ %>
  <div class="flash flash-info">Set your LLM and Embeddings API Keys to unlock AI generation features.<button class="dismiss" onclick="this.parentElement.remove()">Dismiss</button></div>
  <% } %>


  <div class="dash-card">
    <div class="dash-card-header">
      <h2>Profile</h2>
    </div>
    <div class="dash-card-body">
      <form action="/settings/changeFName" method="POST" class="flex gap-1" style="display:flex; gap:0.5rem; align-items:end;margin-bottom:1rem">
        <div class="form-group" style="flex:1;margin:0"><label for="firstName">First Name</label><input type="text" value="<%=user?.user_metadata.first_name || ""%>" name="firstName" required></div>
        <div class="form-group" style="flex:1;margin:0"><label for="lastName">last Name</label><input type="text" value="<%=user?.user_metadata.last_name || ""%>" name="lastName" required></div>
        <button type="submit" class="btn btn-primary">Update Name</button>
      </form>
    </div>
  </div>

  <div class="dash-card">
    <div class="dash-card-header">
      <h2>Grade Level</h2>
    </div>
    <div class="dash-card-body">
      <form method="POST" action="/settings/changeGrade" class="flex gap-1" style="display:flex; gap:0.5rem; align-items:end;">
        <div class="form-group" style="flex:1; margin:0;">
          <select name="grade" required>
            <% const grades = ['9','10','11','12','Gap Year','Other','I am not a student']; %>
            <% grades.forEach(function(g) { %>
            <option value="<%= g %>" <%= (user?.user_metadata?.grade === g) ? 'selected' : '' %>><%= g %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn-primary btn-sm">Update</button>
      </form>
    </div>
  </div>

  <div class="dash-card">
    <div class="dash-card-header">
      <h2>API Keys</h2>
    </div>
    <div class="dash-card-body">
      <form action="/settings/changeLLMkey" method="POST" class="flex gap-1" style="display:flex; gap:0.5rem; align-items:end;">
        <div class="form-group" style="flex:1; margin:0;">
          <label for="llmkey">LLM API Key</label>
          <input type="password" name="llmkey" placeholder="sk-..." required>
        </div>
        <button type="submit" class="btn-primary btn-sm">Save</button>
      </form>
      <form action="/settings/changeEmbeddingKey" method="POST" class="flex gap-1" style="display:flex; gap:0.5rem; align-items:end;">
        <div class="form-group" style="flex:1; margin:0;">
          <label for="embeddingkey">Embeddings API Key</label>
          <input type="password" name="embeddingkey" placeholder="sk-..." required>
        </div>
        <button type="submit" class="btn-primary btn-sm">Save</button>
      </form>
    </div>
  </div>



  <div class="dash-card">
    <div class="dash-card-header">
      <h2>Preferences</h2>
    </div>
    <div class="dash-card-body">
      <form action="/settings/changeLeaderboardStatus" method="POST" class="flex gap-1" style="display:flex; gap:0.5rem; align-items:end;">
        <div class="form-group" style="flex:1; margin:0;">
          <label for="leaderboardstatus">Leaderboard Status</label>
          <select name="leaderboardstatus" required>
            <option value="enabled" <%= (user?.user_metadata?.leaderboardStatus === 'enabled') ? 'selected' : '' %>>Enabled</option>
            <option value="disabled" <%= (user?.user_metadata?.leaderboardStatus === 'disabled') ? 'selected' : '' %>>Disabled</option>
          </select>
        </div>
        <button type="submit" class="btn-primary btn-sm">Save</button>
      </form>
      <form action="/settings/changeEmbeddingKey" method="POST" class="flex gap-1" style="display:flex; gap:0.5rem; align-items:end;">
        <div class="form-group" style="flex:1; margin:0;">
          <label for="embeddingkey">Embeddings API Key</label>
          <input type="password" name="embeddingkey" placeholder="sk-..." required>
        </div>
        <button type="submit" class="btn-primary btn-sm">Save</button>
      </form>
    </div>
  </div>
<% title='Settings' %>
<div class="dashboard">
  <div class="dash-header">
    <h1>Settings</h1>
    <p class="dash-subtitle">Manage your account and preferences</p>
  </div>
  <% if (typeof error !== 'undefined' && error){ %>
  <div class="flash flash-error"><%= error %><button class="dismiss" onclick="this.parentElement.remove()"><img src="/img/icon-close.svg" alt="" width="14" height="14"></button></div>
  <%}%>
  <% if (typeof success !== 'undefined' && success){ %>
  <div class="flash flash-success"><%= success %><button class="dismiss" onclick="this.parentElement.remove()"><img src="/img/icon-close.svg" alt="" width="14" height="14"></button></div>
  <% } %>
  <% if (typeof prompt !== 'undefined' && prompt === "complete-profile"){ %>
  <div class="flash flash-warning">Please complete your profile to access all features.<button class="dismiss" onclick="this.parentElement.remove()"><img src="/img/icon-close.svg" alt="" width="14" height="14"></button></div>
  <% }else if(typeof prompt !== 'undefined' && prompt==="complete-apikeys"){ %>
  <div class="flash flash-info">Set your LLM and Embeddings API Keys to unlock AI generation features.<button class="dismiss" onclick="this.parentElement.remove()"><img src="/img/icon-close.svg" alt="" width="14" height="14"></button></div>
  <% } %>

  <form action="/settings/update-all" method="POST" data-loading>
    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Profile</h2>
      </div>
      <div class="dash-card-body">
        <div class="settings-form-row">
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName" value="<%= (profile && profile.first_name) || '' %>" required maxlength="100">
          </div>
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName" value="<%= (profile && profile.last_name) || '' %>" required maxlength="100">
          </div>
        </div>
        <div class="settings-form-row">
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="<%= (profile && profile.email) || '' %>" readonly class="settings-readonly">
          </div>
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="school">School</label>
            <input type="text" id="school" name="school" value="<%= (profile && profile.school) || '' %>" required maxlength="200">
          </div>
        </div>
        <div class="settings-form-row">
          <div class="form-group" style="flex:1;min-width:150px;">
            <label for="grade">Grade Level</label>
            <select id="grade" name="grade">
              <option value="">— Select —</option>
              <% ['9','10','11','12','Gap Year','I am not a student'].forEach(function(g) { %>
              <option value="<%= g %>" <%= (profile && profile.grade === g) ? 'selected' : '' %>><%= g %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="flex:1;min-width:150px;">
            <label for="gender">Gender</label>
            <select id="gender" name="gender">
              <option value="">— Select —</option>
              <option value="male" <%= (profile && profile.gender === 'male') ? 'selected' : '' %>>Male</option>
              <option value="female" <%= (profile && profile.gender === 'female') ? 'selected' : '' %>>Female</option>
            </select>
          </div>
          <div class="form-group" style="flex:1;min-width:150px;">
            <label for="birthdate">Birthdate</label>
            <input type="date" id="birthdate" name="birthdate" value="<%= (profile && profile.birthdate) || '' %>">
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>API Keys</h2>
      </div>
      <div class="dash-card-body">
        <div class="settings-form-row">
          <div class="form-group" style="flex:1;min-width:250px;">
            <label for="llmKey">LLM API Key</label>
            <input type="password" id="llmKey" name="llmKey" autocomplete="off" placeholder="<%= (profile && profile.llm_apikey) ? '••••••••••••' : 'Enter your API key' %>">
          </div>
          <div class="form-group" style="flex:1;min-width:250px;">
            <label for="embeddingKey">Embedding API Key</label>
            <input type="password" id="embeddingKey" name="embeddingKey" autocomplete="off" placeholder="<%= (profile && profile.embedding_apikey) ? '••••••••••••' : 'Enter your API key' %>">
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Avatar</h2>
      </div>
      <div class="dash-card-body">
        <div class="settings-avatar-wrap">
          <div class="settings-avatar-main">
            <img src="<%= (profile && profile.avatar_url) || '/img/auth.svg' %>" alt="Avatar" id="avatar-preview" class="setting-avatar-img" onerror="this.src='/img/auth.svg'">
          </div>
          <div class="settings-avatar-upload">
            <div class="form-group" style="margin:0 0 0.5rem;">
              <label>Upload Image</label>
              <div class="settings-upload-row">
                <input type="file" name="avatar" accept="image/png,image/jpeg,image/gif,image/webp" id="avatar-file-input" style="flex:1;font-size:0.85rem;">
                <button type="button" class="btn-primary btn-sm" id="avatar-upload-btn" onclick="uploadAvatar()">Upload</button>
              </div>
              <div id="avatar-upload-status" class="settings-upload-status"></div>
            </div>
            <div class="form-group" style="margin:0;">
              <label for="avatarUrl">Or paste image URL</label>
              <input type="url" id="avatarUrl" name="avatarUrl" placeholder="https://example.com/avatar.jpg" value="<%= (profile && profile.avatar_url) || '' %>" oninput="document.getElementById('avatar-preview').src=this.value||'';document.getElementById('avatar-preview').style.display='block'">
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Preferences</h2>
      </div>
      <div class="dash-card-body">
        <div class="settings-form-row">
          <div class="form-group" style="flex:1;min-width:200px;">
            <label for="leaderboardstatus">Leaderboard</label>
            <select id="leaderboardstatus" name="leaderboardstatus">
              <option value="enabled" <%= (!profile || profile.participate_in_leaderboard !== false) ? 'selected' : '' %>>Enabled</option>
              <option value="disabled" <%= (profile && profile.participate_in_leaderboard === false) ? 'selected' : '' %>>Disabled</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Account Info</h2>
      </div>
      <div class="dash-card-body">
        <div class="mini-stat-grid">
          <div class="mini-stat">
            <div class="mini-stat-value"><%= (profile && profile.first_login) ? new Date(profile.first_login).toLocaleDateString() : '—' %></div>
            <div class="mini-stat-label">Member Since</div>
          </div>
          <div class="mini-stat">
            <div class="mini-stat-value"><%= (profile && profile.last_login) ? new Date(profile.last_login).toLocaleDateString() : '—' %></div>
            <div class="mini-stat-label">Last Login</div>
          </div>
        </div>
        <div class="settings-info-block">
          <strong>Model:</strong> Default <br>
          <strong>LLM Key:</strong> <%= (profile && profile.llm_apikey) ? '<img src="/img/icon-check.svg" alt="" width="14" height="14" style="vertical-align:-2px"> Set' : '<img src="/img/icon-x.svg" alt="" width="14" height="14" style="vertical-align:-2px"> Not set' %><br>
          <strong>Embed Key:</strong> <%= (profile && profile.embedding_apikey) ? '<img src="/img/icon-check.svg" alt="" width="14" height="14" style="vertical-align:-2px"> Set' : '<img src="/img/icon-x.svg" alt="" width="14" height="14" style="vertical-align:-2px"> Not set' %>
        </div>
      </div>
    </div>

    <div class="settings-submit">
      <button type="submit" class="btn-primary btn-lg">Save All Settings</button>
    </div>
  </form>
</div>
<script>
  async function uploadAvatar() {
    const fileInput = document.getElementById('avatar-file-input');
    const status = document.getElementById('avatar-upload-status');
    const btn = document.getElementById('avatar-upload-btn');
    if (!fileInput.files.length) {
      status.textContent = 'Please select a file first.';
      status.style.color = 'var(--color-error, red)';
      return;
    }
    btn.disabled = true;
    btn.textContent = 'Uploading...';
    status.textContent = '';
    const formData = new FormData();
    formData.append('avatar', fileInput.files[0]);
    try {
      const res = await fetch('/settings/avatar/upload', {
        method: 'POST',
        body: formData
      });
      const data = await res.json();
      if (data.url) {
        document.getElementById('avatar-preview').src = data.url;
        document.getElementById('avatar-preview').style.display = 'block';
        document.getElementById('avatarUrl').value = data.url;
        status.textContent = 'Avatar uploaded!';
        status.style.color = 'var(--color-success, green)';
        fileInput.value = '';
      } else {
        status.textContent = data.error || 'Upload failed';
        status.style.color = 'var(--color-error, red)';
      }
    } catch (e) {
      status.textContent = 'Upload failed: ' + e.message;
      status.style.color = 'var(--color-error, red)';
    }
    btn.disabled = false;
    btn.textContent = 'Upload';
  }
</script>
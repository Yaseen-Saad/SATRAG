<% if (typeof error !== 'undefined' && error) { %>
<div class="flash flash-error">
  <span><%= error %></span>
  <button class="flash-dismiss" aria-label="Dismiss">×</button>
</div>
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
<div class="flash flash-success">
  <span><%= success %></span>
  <button class="flash-dismiss" aria-label="Dismiss">×</button>
</div>
<% } %>
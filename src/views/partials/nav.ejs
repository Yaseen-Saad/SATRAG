      </template>
      <template x-if="$store.theme.light">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#000000cc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">

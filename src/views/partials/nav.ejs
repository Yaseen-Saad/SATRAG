<a href="#main-content" class="skip-to-content">Skip to main content</a>

<nav class="navbar" x-data="mobileNav()">
  <div class="navbar-inner">
    <a href="/" class="navbar-brand">
      <img width="200" height="80" src="/img/nav.svg" alt="SATrack">
    </a>
    <button class="hamburger" @click="toggle()" aria-label="Menu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
    <button class="theme-btn" @click="$store.theme.toggle()" :aria-pressed="$store.theme.dark" aria-label="Toggle dark mode">
      <img x-if="$store.theme.dark" src="/img/dark.svg" alt="Dark mode">
      <img x-if="$store.theme.light" src="/img/light.svg" alt="Light mode">
    </button>
    <div class="nav-links" id="nav-links">

      <a href="/vocab" class="nav-link">Words</a>
      <a href="/practice" class="nav-link">Practice</a>
      <a href="/flashcards" class="nav-link">Flashcards</a>
      <% if(typeof user !== 'undefined' && user) {%>
      <a href="/dashboard" class="nav-link">Dashboard</a>
      <a href="/dashboard/leaderboard" class="nav-link">Leaderboard</a>
      <a href="/dashboard/analytics" class="nav-link">Analytics</a>
      <a href="/settings" class="nav-link">Settings</a>
      <a href="/auth/logout" class="nav-link nav-link--signout">Sign Out</a>
      <% } else{%>
      <a href="/auth/login" class="nav-link">Log In</a>
      <a href="/auth/signup" class="btn btn-primary btn-sm">Sign Up</a>
      <% } %>
    </div>
  </div>
</nav>

<div class="overlay" id="overlay" @click="close()"></div>